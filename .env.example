# Server
SERVER_IP=YOUR_VPS_PUBLIC_IP
TZ=Asia/Karachi

# WireGuard
WG_PORT=51820
WG_SUBNET=10.0.0.0/24
SERVER_WG_PUBKEY=        # get after first boot: docker exec wg cat /config/server/publickey

# Database
DB_NAME=radius
DB_USER=radius
DB_PASS=your_strong_password_here

# RADIUS — must match MikroTik router secret
RADIUS_SECRET=your_strong_secret_here

# App
APP_IMAGE=ghcr.io/ahmadjavaiddev/command-portal-backend:latest

# Clerk
CLERK_PUBLISHABLE_KEY=pk_xxx
CLERK_SECRET_KEY=sk_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx